FROM golang:1.21-alpine AS builder
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /app/producer main.go

FROM alpine:3.18
RUN apk add --no-cache ca-certificates
COPY --from=builder /app/producer /usr/local/bin/producer
EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/producer"]
